* text=auto

# 소스 코드 파일은 LF로 고정
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md   text eol=lf

# 바이너리 파일은 줄바꿈 변환 제외
*.png  -text
*.jpg  -text
*.jpeg -text
*.gif  -text
*.webp -text
*.svg  -text
*.ico  -text
*.ttf  -text
*.otf  -text
*.woff -text
*.woff2 -text
